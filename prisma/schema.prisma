generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------
enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  NOT_REQUIRED
}

// ------------------------------------------------------
// MODELOS
// ------------------------------------------------------
model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  
  documents Document[]
  notes     Note[]     // NUEVO: El usuario ahora es dueño directo de sus notas
  folders   Folder[]   // NUEVO: El usuario es dueño de sus carpetas
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Folder {
  id        Int        @id @default(autoincrement())
  name      String
  type      String     // "DOCUMENT" o "NOTE" para separar visualmente en el frontend
  
  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  documents Document[]
  notes     Note[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
  @@map("folders")
}

model Document {
  id         Int        @id @default(autoincrement())
  title      String
  filePath   String
  ocrStatus  OcrStatus  @default(PENDING) 
  
  isFavorite Boolean    @default(false) // NUEVO: Sistema de favoritos

  userId     Int
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // NUEVO: Relación opcional con una Carpeta
  folderId   Int?
  folder     Folder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)

  // NUEVA RELACIÓN MUCHOS A MUCHOS (Una nota en muchos PDFs, un PDF con muchas notas)
  globalNotes Note[]    @relation("GlobalDocumentNotes")

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
  @@index([folderId])
  @@map("documents")
}

model Note {
  id         Int        @id @default(autoincrement())
  title      String
  content    String     @db.LongText
  highlights Json

  isFavorite Boolean    @default(false)

  // 1. El dueño ahora es OBLIGATORIO (le quitamos el "?")
  userId     Int        
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  folderId   Int?
  folder     Folder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)

  // 2. ELIMINAMOS POR COMPLETO documentId y oldDocument

  // 3. Mantenemos la relación Muchos a Muchos intacta
  documents  Document[] @relation("GlobalDocumentNotes")

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
  @@index([folderId])
  @@map("notes")
}